# Copy to .env.local and fill in the secrets. See docs/production-setup-status.md.

# Canonical site origin - used for metadata, sitemap, RSS, JSON-LD, and emails.
# Use http://localhost:3000 locally and the final public URL on Vercel.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Public Sanity project coordinates. Safe to expose.
NEXT_PUBLIC_SANITY_PROJECT_ID="m5flo8s9"
NEXT_PUBLIC_SANITY_DATASET="production"
NEXT_PUBLIC_SANITY_API_VERSION="2026-07-01"

# Viewer token for draft preview in the Studio's presentation tool.
SANITY_API_READ_TOKEN=""

# Shared secret for the publish webhook. Must match the Sanity webhook secret.
SANITY_REVALIDATE_SECRET=""

# Auth.js session secret. Generate with: openssl rand -base64 32
AUTH_SECRET=""

# Neon Postgres connection string, preferably pooled.
DATABASE_URL=""

# Resend transactional email.
RESEND_API_KEY=""
EMAIL_FROM=""

# Optional: Resend Audience to mirror confirmed subscribers into.
RESEND_AUDIENCE_ID=""

# Optional: Google OAuth. Email-link sign-in works without these.
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Required in production: Upstash Redis for rate limiting.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
