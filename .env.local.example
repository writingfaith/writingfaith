# Copy to .env.local and fill in the secrets. See docs/sanity-setup.md.

# Canonical site origin — used for metadata, sitemap, RSS, JSON-LD.
# Set to the production URL on Vercel (e.g. https://writingfaith.com).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Public project coordinates (safe to expose; defaults are in sanity/env.ts).
NEXT_PUBLIC_SANITY_PROJECT_ID="m5flo8s9"
NEXT_PUBLIC_SANITY_DATASET="production"
NEXT_PUBLIC_SANITY_API_VERSION="2026-07-01"

# Viewer token for draft preview in the Studio's presentation tool.
# Create at https://sanity.io/manage → project → API → Tokens (role: Viewer).
SANITY_API_READ_TOKEN=""

# Shared secret for the publish webhook (any long random string).
# Must match the secret configured on the webhook in sanity.io/manage.
SANITY_REVALIDATE_SECRET=""

# ---- Reader accounts & newsletter (Phase 4) — see docs/readers-setup.md ----

# Auth.js session secret. Generate with: openssl rand -base64 32
AUTH_SECRET=""

# Optional owner allowlist for Studio/draft editing.
# Defaults to the address in lib/auth/owner.ts when omitted.
ADMIN_EMAILS=""

# Public contact address. Set this to a neutral alias (e.g. hello@yourdomain)
# to keep a personal address out of the Contact page's mailto: link.
NEXT_PUBLIC_CONTACT_EMAIL=""

# Neon Postgres connection string (pooled), from the Neon dashboard.
DATABASE_URL=""

# Resend: transactional email (sign-in links, confirmations) + broadcasts.
RESEND_API_KEY=""
# Verified sender, e.g. "WritingFaith <hello@writingfaith.com>".
EMAIL_FROM=""
# Optional: Resend Audience to mirror confirmed subscribers into.
RESEND_AUDIENCE_ID=""
# Optional: send a "new subscriber" notification to this address whenever
# someone confirms their subscription. Also used as the Reply-To address on
# the subscription-confirmation email, so reader replies land here too.
NEWSLETTER_NOTIFY_EMAIL=""

# Authorizes the scheduled-essay cron sweep (vercel.json). Generate with:
# openssl rand -base64 32
CRON_SECRET=""

# Optional: Google OAuth (sign-in works with email links alone).
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Optional in dev, required in production: Upstash Redis for rate limiting.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
